# URL pública do seu projeto Supabase
# Exemplo: https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=

# Chave anônima (public / anon) do Supabase
# Exemplo: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SUPABASE_ANON_KEY=

# Opcional: e-mails que devem nascer como administradores no primeiro carregamento.
# Pode informar um ou vários, separados por vírgula.
# Exemplo: admin@escola.local,coordenacao@escola.com
VITE_DEFAULT_ADMIN_EMAILS=admin@escola.local
