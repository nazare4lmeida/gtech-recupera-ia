PORT=3001

# Se não preencher as variáveis abaixo, o servidor usa server/data/db.json
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Tabelas exclusivas deste projeto.
# Isso permite usar o MESMO projeto do Supabase do fullstack sem misturar dados.
RESULTS_TABLE=ia_results
RECOVERY_RESULTS_TABLE=ia_recovery_results
PRESENCA_RESULTS_TABLE=ia_practice_results

ADMIN_EMAIL=admin@exemplo.com
ADMIN_ACCESS_CODE=123456
